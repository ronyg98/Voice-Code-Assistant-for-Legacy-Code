# Copy to .env and fill in your keys. Only OPENAI_API_KEY is required
# (Whisper STT, TTS, embeddings); the others extend the LLM failover chain.
OPENAI_API_KEY = "sk-..."
GROQ_API_KEY = "gsk_..."
GOOGLE_API_KEY = ""
MISTRAL_API_KEY = ""

